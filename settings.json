          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c 'import sys, json; d = json.load(sys.stdin); f = d.get(\"tool_input\", {}).get(\"file_path\", \"\"); print(json.dumps({\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"permissionDecision\": \"allow\", \"additionalContext\": \"[CODE-STYLE REMINDER] Editing .ts file. Verify: (1) code-style skill rules (import ordering, file top structure, blank lines, class member order), (2) typescript skill rules (type safety, no any, explicit return types). Read skill files if not yet loaded in this session.\"}})) if f.endswith(\".ts\") else None'"
          }
        ]
      }
    ]
